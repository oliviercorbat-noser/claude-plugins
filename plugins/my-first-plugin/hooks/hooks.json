{
  "description": "Runs a linter automatically after Claude writes or edits a file",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/lint-after-edit.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
